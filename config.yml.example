# bash-pve-utils declarative configuration
# Copy to config.yml and customize for your Proxmox environment.

# Storage configuration
storage: local-lvm            # Storage pool for container rootfs
template_storage: local       # Storage pool for LXC templates

# Container definitions
containers:
  # ── HTTP probe host (Debian 12) ─────────────────────────────────
  - vmid: 900
    hostname: net-probe-host          # Container hostname
    cores: 2                          # vCPU cores
    memory: 1024                      # RAM in MB
    swap: 512                         # Swap in MB
    disk: 8G                          # Root filesystem size
    ostemplate: debian-12-standard_12.2-1_amd64.tar.zst
    bridge: vmbr0                     # Network bridge
    ip: dhcp                          # IP config (dhcp or static, e.g. 192.168.1.100/24)
    gateway: ""                       # Gateway for static IP (leave empty for dhcp)
    ssh_key: ssh-ed25519 AAAA...      # Public key for root access
    onboot: true                      # Start on Proxmox boot
    bootstrap: |                      # Post-creation commands
      apt-get update
      apt-get install -y curl git

  # ── Redis cache (Alpine 3.19) ───────────────────────────────────
  - vmid: 901
    hostname: goshrt-db
    cores: 1
    memory: 512
    swap: 256
    disk: 4G
    ostemplate: alpine-3.19-default_20231207_amd64.tar.xz
    bridge: vmbr0
    ip: 192.168.1.200/24
    gateway: 192.168.1.1
    ssh_key: ssh-ed25519 AAAA...
    onboot: false
    bootstrap: |
      apk update
      apk add redis
