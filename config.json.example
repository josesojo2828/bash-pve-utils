{
  "storage": "local-lvm",
  "template_storage": "local",
  "containers": [
    {
      "vmid": 900,
      "hostname": "net-probe-host",
      "cores": 2,
      "memory": 1024,
      "swap": 512,
      "disk": "8G",
      "ostemplate": "system/debian-12-standard_12.2-1_amd64.tar.zst",
      "bridge": "vmbr0",
      "ip": "dhcp",
      "gateway": "",
      "ssh_key": "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIP...",
      "onboot": 1,
      "bootstrap": "apt-get update && apt-get install -y curl git"
    },
    {
      "vmid": 901,
      "hostname": "goshrt-db",
      "cores": 1,
      "memory": 512,
      "swap": 256,
      "disk": "4G",
      "ostemplate": "system/alpine-3.19-default_20231207_amd64.tar.xz",
      "bridge": "vmbr0",
      "ip": "192.168.1.200/24",
      "gateway": "192.168.1.1",
      "ssh_key": "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIP...",
      "onboot": 0,
      "bootstrap": "apk update && apk add redis"
    }
  ]
}
